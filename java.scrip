// Sichqonchaga qarab yengil Parallax effekti
document.addEventListener('mousemove', (e) => {
    const x = (window.innerWidth / 2 - e.clientX) / 40;
    const y = (window.innerHeight / 2 - e.clientY) / 40;
    
    document.querySelector('.glass-container').style.transform = 
        `rotateY(${x}deg) rotateX(${y}deg)`;
    
    // Blob-larni biroz qimirlatish
    document.querySelector('.blob-1').style.transform = `translate(${x*2}px, ${y*2}px)`;
});
